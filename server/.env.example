# Aerogarage API — Environment Variables

# ── Core ──────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (M30+ recommended for production)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED in production — use a strong random secret (openssl rand -hex 64)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────────────────────────────────────
JSON_LIMIT=200kb
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=180
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=25

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Enables distributed rate limiting across multiple server instances.
# Falls back to in-memory rate limiting if not set.
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://<user>:<password>@<host>:<port>   ← Upstash / Redis Cloud

# ── SMTP Email (optional) ─────────────────────────────────────────────────────
# Enables registration verification emails and password reset flows.
# Falls back to console logging if not set (development only).
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=<your_resend_api_key>
# SMTP_FROM=noreply@aerogarage.com

# ── Sentry Error Monitoring (optional) ───────────────────────────────────────
# Get DSN from https://sentry.io → Project → Settings → Client Keys
# Leave empty in development to disable Sentry.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── API Documentation ─────────────────────────────────────────────────────────
# Secret key required to access /api/docs in production.
# Use: GET /api/docs?key=<value> or header x-docs-key: <value>
# Generate: openssl rand -hex 32
# Leave empty to disable docs protection (only in development).
# DOCS_SECRET_KEY=your_docs_secret_key_here
